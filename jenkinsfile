pipeline {

    agent any
 
    stages {
 
        stage('Clone') {

            steps {

                echo 'Cloning Code'

            }

        }
 
        stage('Build Backend') {

            steps {

                sh 'docker build -t backend-app ./backend'

            }

        }
 
        stage('Build Frontend') {

            steps {

                sh 'docker build -t frontend-app ./frontend'

            }

        }
 
        stage('Deploy') {

            steps {

                sh 'docker-compose up -d'

            }

        }

    }

}
 